# =============================================================================
# .env.example — copy this file to .env and replace every value marked CHANGE.
# .env is gitignored and must never be committed to version control.
# =============================================================================

# --- MongoDB ---
MONGO_DB_USERNAME=root
# CHANGE: use a strong password (e.g. openssl rand -base64 32)
MONGO_DB_PASSWORD=CHANGE_ME
MONGO_DB_PORT=27017

# --- PostgreSQL ---
POSTGRESQL_DB_USERNAME=root
# CHANGE: use a strong password (e.g. openssl rand -base64 32)
POSTGRESQL_DB_PASSWORD=CHANGE_ME
POSTGRESQL_DB_PORT=5432

# --- JWT ---
# CHANGE: generate with: openssl rand -base64 48
# Must be at least 32 characters. The same value must be set here for both
# api-gateway (validates tokens) and customer-microservice (signs tokens).
JWT_SECRET=CHANGE_ME

# --- Config Server ---
CONFIG_SERVER_PORT=8888

# --- Eureka ---
EUREKA_SERVER_PORT=8761

# --- Customer Microservice ---
CUSTOMER_DB_NAME=customer_db
CUSTOMER_MICROSERVICE_PORT=8091

# --- Product Microservice ---
PRODUCT_DB_NAME=product_db
PRODUCT_MICROSERVICE_PORT=8092

# --- Cart Microservice ---
CART_DB_NAME=cart_db
CART_MICROSERVICE_PORT=8093

# --- Order Microservice ---
ORDER_DB_NAME=order_db
ORDER_MICROSERVICE_PORT=8094

# --- Payment Microservice ---
PAYMENT_DB_NAME=payment_db
PAYMENT_MICROSERVICE_PORT=8095

# --- Notification Microservice ---
NOTIFICATION_MICROSERVICE_PORT=8096
NOTIFICATION_DB_NAME=notification_db

# --- Mail (SMTP) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
# CHANGE: your Gmail address
MAIL_USERNAME=CHANGE_ME
# CHANGE: Gmail App Password (not your login password).
# Generate one at https://myaccount.google.com/apppasswords
MAIL_PASSWORD=CHANGE_ME

# --- Twilio (WhatsApp notifications) ---
# CHANGE: obtain from https://console.twilio.com
TWILIO_ACCOUNT_SID=CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
# Format: whatsapp:+14155238886 (Twilio sandbox) or your approved number
TWILIO_WHATSAPP_FROM=CHANGE_ME

# --- API Gateway ---
API_GATEWAY_PORT=8222

# --- nginx + Let's Encrypt ---
# CHANGE: your public domain (DNS A record must point to this server before running init-letsencrypt.sh)
DOMAIN_NAME=CHANGE_ME
# CHANGE: email used for Let's Encrypt expiry notifications
CERTBOT_EMAIL=CHANGE_ME

# --- Prometheus ---
PROMETHEUS_PORT=9090

# --- Grafana ---
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
# CHANGE: use a strong password
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
